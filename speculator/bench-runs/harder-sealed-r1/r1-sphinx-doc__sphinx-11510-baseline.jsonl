{"t":1784656901877,"epoch":0,"type":"edit","changes":[{"path":"/var/folders/1k/khz1c9xs5qg4tx7kv2j6rwbr0000gn/T/spex-bench-RgGvA5/sphinx/directives/other.py","kind":{"type":"update","move_path":null},"diff":"@@ -5,3 +5,3 @@\n \n-from docutils import nodes\n+from docutils import nodes, statemachine\n from docutils.parsers.rst import directives\n@@ -378,4 +378,27 @@\n         self.env.note_included(filename)\n-        return super().run()\n \n+        # ``source-read`` is normally emitted by SphinxStandaloneReader, but\n+        # docutils reads included files directly.  Intercept the input after\n+        # docutils has applied the include directive's clipping options and\n+        # before it is inserted into the parser's input stream.\n+        insert_input = self.state_machine.insert_input\n+\n+        def insert_input_with_source_read(include_lines: list[str], source: str) -> None:\n+            # BaseInclude adds these two lines to mark the end of the include.\n+            content, marker = include_lines[:-2], include_lines[-2:]\n+            arg = ['\\n'.join(content)]\n+            docname = self.env.path2doc(filename) or rel_filename\n+            self.env.events.emit('source-read', docname, arg)\n+            lines = statemachine.string2lines(\n+                arg[0], self.state.document.settings.tab_width,\n+                convert_whitespace=True,\n+            )\n+            insert_input(lines + marker, source)\n+\n+        self.state_machine.insert_input = insert_input_with_source_read\n+        try:\n+            return super().run()\n+        finally:\n+            self.state_machine.insert_input = insert_input\n+\n \n"}],"sig":"EDIT(py)","threadId":"019f85d6-7e3b-7f12-ba93-7a25e9eb8835","sessionId":"019f85d6-7e3b-7f12-ba93-7a25e9eb8835","workspaceId":"16777231:98448349"}
