{"t":1784651395416,"epoch":1,"type":"edit","changes":[{"path":"/var/folders/1k/khz1c9xs5qg4tx7kv2j6rwbr0000gn/T/spex-bench-n7XkEb/sphinx/domains/cpp.py","kind":{"type":"update","move_path":null},"diff":"@@ -884,2 +884,25 @@\n \n+class ASTUserDefinedLiteral(ASTLiteral):\n+    def __init__(self, literal: ASTLiteral, suffix: ASTIdentifier) -> None:\n+        self.literal = literal\n+        self.suffix = suffix\n+\n+    def _stringify(self, transform: StringifyTransform) -> str:\n+        return transform(self.literal) + transform(self.suffix)\n+\n+    def get_id(self, version: int) -> str:\n+        if version == 1:\n+            raise NoOldIdError()\n+        # A user-defined literal is a call to operator\"\"suffix.\n+        operator = ASTOperatorLiteral(self.suffix)\n+        return 'clL_Z%sE%sE' % (operator.get_id(version),\n+                                self.literal.get_id(version))\n+\n+    def describe_signature(self, signode: TextElement, mode: str,\n+                           env: \"BuildEnvironment\", symbol: \"Symbol\") -> None:\n+        self.literal.describe_signature(signode, mode, env, symbol)\n+        txt = str(self.suffix)\n+        signode.append(nodes.Text(txt, txt))\n+\n+\n class ASTThisLiteral(ASTExpression):\n@@ -4660,2 +4683,10 @@\n             return ASTBooleanLiteral(False)\n+\n+        def user_defined(literal: ASTLiteral) -> ASTLiteral:\n+            # There may be no whitespace between a literal and its ud-suffix.\n+            if self.match(identifier_re):\n+                return ASTUserDefinedLiteral(\n+                    literal, ASTIdentifier(self.matched_text))\n+            return literal\n+\n         for regex in [float_literal_re, binary_literal_re, hex_literal_re,\n@@ -4664,5 +4695,11 @@\n             if self.match(regex):\n-                while self.current_char in 'uUlLfF':\n-                    self.pos += 1\n-                return ASTNumberLiteral(self.definition[pos:self.pos])\n+                literal_end = self.pos\n+                if self.match(identifier_re):\n+                    suffix = self.matched_text\n+                    if all(c in 'uUlLfF' for c in suffix):\n+                        return ASTNumberLiteral(self.definition[pos:self.pos])\n+                    self.pos = literal_end\n+                    return user_defined(ASTNumberLiteral(\n+                        self.definition[pos:literal_end]))\n+                return ASTNumberLiteral(self.definition[pos:literal_end])\n \n@@ -4670,3 +4707,3 @@\n         if string is not None:\n-            return ASTStringLiteral(string)\n+            return user_defined(ASTStringLiteral(string))\n \n@@ -4677,3 +4714,3 @@\n             try:\n-                return ASTCharLiteral(prefix, data)\n+                return user_defined(ASTCharLiteral(prefix, data))\n             except UnicodeDecodeError as e:\n@@ -4683,4 +4720,2 @@\n                           \" resulting in multiple decoded characters.\")\n-\n-        # TODO: user-defined lit\n         return None\n"}],"sig":"EDIT(py)","threadId":"019f8582-831e-71d3-a108-5d792fd793a0","sessionId":"019f8582-831e-71d3-a108-5d792fd793a0","workspaceId":"16777231:95638586"}
